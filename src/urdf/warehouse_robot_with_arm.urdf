<?xml version="1.0"?>
<robot name="warehouse_robot">
  
  <!-- Base Link - optimized for stability -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.28" length="0.18"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.28" length="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="25"/>
      <origin xyz="0 0 -0.02"/>
      <inertia ixx="0.492" ixy="0" ixz="0" iyy="0.492" iyz="0" izz="0.980"/>
    </inertial>
  </link>

  <!-- Heavy ballast weight positioned low for stability -->
  <link name="ballast_weight">
    <visual>
      <geometry>
        <cylinder radius="0.25" length="0.15"/> 
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.25" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="25"/>  
      <origin xyz="0 0 0"/>
      <inertia ixx="0.547" ixy="0" ixz="0" iyy="0.547" iyz="0" izz="0.781"/>
    </inertial>
  </link>

  <joint name="ballast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ballast_weight"/>
    <origin xyz="0 0 -0.165" rpy="0 0 0"/> 
  </joint>

  <!-- Rear counterweight for arm balance -->
  <link name="rear_counterweight">
    <visual>
      <geometry>
        <box size="0.12 0.25 0.08"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.25 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="8"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.043" ixy="0" ixz="0" iyy="0.016" iyz="0" izz="0.053"/>
    </inertial>
  </link>

  <joint name="rear_counterweight_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_counterweight"/>
    <origin xyz="-0.18 0 -0.13" rpy="0 0 0"/>
  </joint>

  <!-- Stabilizer plates for better balance -->
  <link name="front_stabilizer">
    <visual>
      <geometry>
        <box size="0.15 0.30 0.02"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.30 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.011" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.014"/>
    </inertial>
  </link>

  <joint name="front_stabilizer_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_stabilizer"/>
    <origin xyz="0.20 0 -0.17" rpy="0 0 0"/>
  </joint>

  <link name="rear_stabilizer">
    <visual>
      <geometry>
        <box size="0.15 0.30 0.02"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.30 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.011" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.014"/>
    </inertial>
  </link>

  <joint name="rear_stabilizer_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_stabilizer"/>
    <origin xyz="-0.20 0 -0.17" rpy="0 0 0"/>
  </joint>

  <!-- Four Mecanum wheels positioned to touch ground -->
  
  <!-- Front left Mecanum wheel -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="mecanum_wheel">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
      <origin rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.18 0.20 -0.17" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Front right Mecanum wheel -->
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="mecanum_wheel">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
      <origin rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.18 -0.20 -0.17" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Rear left Mecanum wheel -->
  <link name="rear_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="mecanum_wheel">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
      <origin rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.18 0.20 -0.17" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Rear right Mecanum wheel -->
  <link name="rear_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="mecanum_wheel">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
      <origin rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.18 -0.20 -0.17" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Laser Scanner -->
  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.15 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- Front Camera -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.22 0 -0.05" rpy="0 0.35 0"/>
  </joint>

  <!-- Robotic Arm with optimized mass distribution -->
  
  <!-- Arm Base -->
  <link name="arm_base_link">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.12"/> 
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.024" ixy="0" ixz="0" iyy="0.024" iyz="0" izz="0.013"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/> 
  </joint>

  <!-- Shoulder Link -->
  <link name="shoulder_link">
    <visual>
      <geometry>
        <box size="0.08 0.06 0.12"/>
      </geometry>
      <material name="arm_blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.06 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 0.06"/>
      <inertia ixx="0.007" ixy="0" ixz="0" iyy="0.009" iyz="0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="1.2"/> 
    <dynamics damping="0.4" friction="0.05"/>
  </joint>

  <!-- Upper Arm Link -->
  <link name="upper_arm_link">
    <visual>
      <geometry>
        <box size="0.06 0.05 0.22"/> 
      </geometry>
      <material name="arm_green">
        <color rgba="0.2 0.8 0.4 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.05 0.22"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.11"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.009" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.3" upper="1.3" effort="60" velocity="1.2"/> 
    <dynamics damping="0.4" friction="0.05"/>
  </joint>

  <!-- Forearm Link -->
  <link name="forearm_link">
    <visual>
      <geometry>
        <box size="0.05 0.04 0.18"/> 
      </geometry>
      <material name="arm_orange">
        <color rgba="1.0 0.5 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.04 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.09"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="40" velocity="1.2"/>  
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Wrist Link -->
  <link name="wrist_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.08"/>
      </geometry>
      <material name="arm_red">
        <color rgba="0.8 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.04"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0006"/>
    </inertial>
  </link>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="30" velocity="1.2"/> 
    <dynamics damping="0.3" friction="0.03"/>
  </joint>

  <!-- Wrist Rotation Link -->
  <link name="wrist_rotate_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.06"/> 
      </geometry>
      <material name="arm_purple">
        <color rgba="0.6 0.2 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.03"/>
      <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0006" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_link"/>
    <child link="wrist_rotate_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="25" velocity="1.2"/>  
    <dynamics damping="0.2" friction="0.03"/>
  </joint>

  <link name="wrist_3_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.05"/>
      </geometry>
      <material name="arm_pink">
        <color rgba="0.8 0.4 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_rotate_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8" effort="25" velocity="1.2"/>
    <dynamics damping="0.2" friction="0.03"/>
  </joint>

  <!-- End Effector Base -->
  <link name="end_effector_link">
    <visual>
      <geometry>
        <box size="0.10 0.08 0.05"/> 
      </geometry>
      <material name="gripper_yellow">
        <color rgba="1.0 1.0 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.10 0.08 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0007"/>
    </inertial>
  </link>

  <joint name="end_effector_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- Left Gripper Finger -->
  <link name="left_gripper_link">
    <visual>
      <geometry>
        <box size="0.03 0.015 0.06"/> 
      </geometry>
      <material name="gripper_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.03"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="left_gripper_joint" type="prismatic">
    <parent link="end_effector_link"/>
    <child link="left_gripper_link"/>
    <origin xyz="0 0.045 0.025" rpy="0 0 0"/> 
    <axis xyz="0 -1 0"/>  
    <limit lower="0" upper="0.04" effort="25" velocity="0.25"/>  
    <dynamics damping="0.2" friction="0.03"/>
  </joint>

  <!-- Right Gripper Finger -->
  <link name="right_gripper_link">
    <visual>
      <geometry>
        <box size="0.03 0.015 0.06"/>
      </geometry>
      <material name="gripper_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.03"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="right_gripper_joint" type="prismatic">
    <parent link="end_effector_link"/>
    <child link="right_gripper_link"/>
    <origin xyz="0 -0.045 0.025" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/>  
    <limit lower="0" upper="0.04" effort="25" velocity="0.25"/>  
    <dynamics damping="0.2" friction="0.03"/>
  </joint>

  <!-- GAZEBO Plugins and Materials -->
  
  <!-- Use 4-wheel independent drive instead of planar move -->
  <gazebo>
    <plugin name="skid_steer_drive_controller" filename="libgazebo_ros_skid_steer_drive.so">
      <updateRate>100.0</updateRate>
      <robotNamespace>/</robotNamespace>
      <leftFrontJoint>front_left_wheel_joint</leftFrontJoint>
      <rightFrontJoint>front_right_wheel_joint</rightFrontJoint>
      <leftRearJoint>rear_left_wheel_joint</leftRearJoint>
      <rightRearJoint>rear_right_wheel_joint</rightRearJoint>
      <wheelSeparation>0.4</wheelSeparation>
      <wheelDiameter>0.16</wheelDiameter>
      <robotBaseFrame>base_link</robotBaseFrame>
      <torque>50</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <broadcastTF>true</broadcastTF>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/warehouse_robot</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
      <legacyModeNS>true</legacyModeNS>
    </plugin>
  </gazebo>

  <!-- Laser Scanner -->
  <gazebo reference="laser_link">
    <sensor type="ray" name="laser_scanner">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Front Camera -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="camera">
      <update_rate>30.0</update_rate>
      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>camera_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Gazebo Material Settings -->
  
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  
  <gazebo reference="ballast_weight">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="rear_counterweight">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="front_stabilizer">
    <material>Gazebo/Grey</material>
  </gazebo>
  
  <gazebo reference="rear_stabilizer">
    <material>Gazebo/Grey</material>
  </gazebo>
  
  <!-- Wheel materials with optimized friction -->
  <gazebo reference="front_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="front_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="rear_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="rear_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  
  <gazebo reference="laser_link">
    <material>Gazebo/Red</material>
  </gazebo>
  
  <gazebo reference="camera_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- Robotic arm materials -->
  <gazebo reference="arm_base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="shoulder_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  
  <gazebo reference="upper_arm_link">
    <material>Gazebo/Green</material>
  </gazebo>
  
  <gazebo reference="forearm_link">
    <material>Gazebo/Orange</material>
  </gazebo>
  
  <gazebo reference="wrist_link">
    <material>Gazebo/Red</material>
  </gazebo>
  
  <gazebo reference="wrist_rotate_link">
    <material>Gazebo/Purple</material>
  </gazebo>
  
  <gazebo reference="wrist_3_link">
    <material>Gazebo/Pink</material>
  </gazebo>
  
  <gazebo reference="end_effector_link">
    <material>Gazebo/Yellow</material>
  </gazebo>
  
  <gazebo reference="left_gripper_link">
    <material>Gazebo/Black</material>
    <mu1>2.0</mu1>  
    <mu2>2.0</mu2>
  </gazebo>
  
  <gazebo reference="right_gripper_link">
    <material>Gazebo/Black</material>
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>

  <!-- Transmission System -->
  
  <transmission name="shoulder_pan_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_pan_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="shoulder_pan_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="shoulder_lift_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_lift_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="shoulder_lift_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="elbow_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="elbow_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="elbow_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="wrist_1_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_1_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="wrist_1_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="wrist_2_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_2_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="wrist_2_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="wrist_3_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_3_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="wrist_3_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="left_gripper_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_gripper_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="left_gripper_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="right_gripper_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="right_gripper_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="right_gripper_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- Grasp Plugin -->
  <gazebo>
    <plugin name="gazebo_grasp_fix" filename="libgazebo_grasp_fix.so">
      <arm>
        <arm_name>warehouse_robot_arm</arm_name>
        <palm_link>end_effector_link</palm_link>
        <gripper_link>left_gripper_link</gripper_link>
        <gripper_link>right_gripper_link</gripper_link>
      </arm>
      <forces_angle_tolerance>100</forces_angle_tolerance>
      <update_rate>5</update_rate>
      <grip_count_threshold>5</grip_count_threshold>
      <max_grip_count>15</max_grip_count>
      <release_tolerance>0.005</release_tolerance>
      <disable_collisions_on_attach>false</disable_collisions_on_attach>
      <contact_topic>__default_topic__</contact_topic>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="object_attacher" filename="libgazebo_ros_link_attacher.so"/>
  </gazebo>

</robot>
